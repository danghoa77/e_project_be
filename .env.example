# E-Commerce Mobile App Environment Configuration
# Copy this file to .env and update with your actual values

# API Configuration
# Update this with your backend URL (where your microservices are running)
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30000

# Stripe Configuration
# Get these from https://stripe.com dashboard
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Google OAuth Configuration
# Get these from Google Cloud Console (APIs & Services > Credentials)
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your-web-client-id.googleusercontent.com

# TalkJS Configuration (Optional - for chat feature)
# Get this from https://talkjs.com dashboard
TALKJS_APP_ID=your-talkjs-app-id

# Development Configuration
DEV_MODE=true
DEBUG_REDUX=true

# Notification Configuration (Optional)
# These will be configured when you set up push notifications
EXPO_PUSH_TOKEN=

# Analytics Configuration (Optional)
# Add your analytics service keys here
ANALYTICS_API_KEY=

# App Configuration
APP_NAME=E-Commerce App
APP_VERSION=1.0.0

# Security Configuration
# You can change these for additional security
JWT_SECRET_FALLBACK=your-jwt-secret-key-fallback
ENCRYPTION_KEY=your-encryption-key

# API Keys for third-party services
# Add any additional API keys your app might need
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Social Media Integration (Optional)
FACEBOOK_APP_ID=
TWITTER_API_KEY=
INSTAGRAM_CLIENT_ID=

# Feature Flags (Optional - to enable/disable features)
ENABLE_GOOGLE_AUTH=true
ENABLE_APPLE_PAY=false
ENABLE_GOOGLE_PAY=false
ENABLE_CHAT=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_ANALYTICS=false

# Backend Service URLs (if different from main API)
USER_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004

# Database Configuration (if mobile app connects directly)
# Usually not needed as the mobile app connects through the API
# DATABASE_URL=mongodb://localhost:27017/ecommerce

# Redis Configuration (if mobile app uses Redis directly)
# Usually not needed as the mobile app connects through the API
# REDIS_URL=redis://localhost:6379

# Email Configuration (if mobile app sends emails directly)
# Usually handled by the backend
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password